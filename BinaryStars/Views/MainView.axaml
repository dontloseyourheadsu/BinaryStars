<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BinaryStars.ViewModels"
             xmlns:m="clr-namespace:BinaryStars.Models"
             xmlns:h="clr-namespace:BinaryStars.Helpers"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="BinaryStars.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="{StaticResource AppBackground}">

  <UserControl.Resources>
    <h:BoolToVisibilityConverter x:Key="BoolToVis" />
    <h:MessageAlignmentConverter x:Key="MsgAlign" />
    <h:MessageBackgroundConverter x:Key="MsgBg" />
    <h:TimestampConverter x:Key="TimeConv" />
    <h:NotNullToVisibilityConverter x:Key="NotNullToVis" />
    <h:FileSizeConverter x:Key="FileSizeConv" />
    <h:ByteArrayToImageSourceConverter x:Key="ByteToImg" />
  </UserControl.Resources>

  <Grid RowDefinitions="Auto, *, Auto, Auto">
    
    <!-- Header -->
    <Border Background="{StaticResource AppPrimary}" Padding="20,15">
      <Grid ColumnDefinitions="*, Auto">
        <TextBlock Text="BinaryStars" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
           <Button Content="SCAN" Command="{Binding StartScanCommand}" Foreground="White" Background="Transparent" BorderThickness="1" BorderBrush="White" Padding="15,5" CornerRadius="4" />
           <Button Content="🗑" Command="{Binding ClearHistoryCommand}" Foreground="White" Background="Transparent" FontSize="20" BorderThickness="0" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Chat Area -->
    <ListBox x:Name="ChatList" Grid.Row="1" ItemsSource="{Binding Messages}" Background="Transparent" BorderThickness="0" Padding="0,10">
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="0" />
          <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent" />
        </Style>
      </ListBox.Styles>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="m:ChatMessage">
          <Grid HorizontalAlignment="{Binding IsMe, Converter={StaticResource MsgAlign}}" Margin="15,3">
            <Border CornerRadius="8" Padding="12,10"
                    Background="{Binding IsMe, Converter={StaticResource MsgBg}}"
                    BorderThickness="1" BorderBrush="#DDDDDD"
                    MaxWidth="320">
              <StackPanel Spacing="5">
                <TextBlock Text="{Binding Sender}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AppPrimary}" 
                           IsVisible="{Binding !IsMe}" Margin="0,0,0,2" />
                
                <!-- Attachment Display -->
                <StackPanel IsVisible="{Binding Attachment, Converter={StaticResource NotNullToVis}}" Spacing="8" Margin="0,0,0,5">
                   <Image Source="{Binding Attachment.Data, Converter={StaticResource ByteToImg}}" 
                          IsVisible="{Binding Attachment.IsImage}"
                          MaxHeight="300" Stretch="Uniform" />
                   <Border Background="#20000000" Padding="10" CornerRadius="6">
                      <Grid ColumnDefinitions="Auto, *">
                         <TextBlock Text="📁" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Black" />
                         <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Attachment.Name}" FontSize="12" FontWeight="SemiBold" Foreground="Black" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Attachment.Size, Converter={StaticResource FileSizeConv}}" FontSize="10" Foreground="Black" Opacity="0.6" />
                         </StackPanel>
                      </Grid>
                   </Border>
                </StackPanel>

                <TextBlock Text="{Binding Text}" Foreground="Black" TextWrapping="Wrap" FontSize="15" />
                <TextBlock Text="{Binding Timestamp, Converter={StaticResource TimeConv}}" FontSize="9" Opacity="0.5" HorizontalAlignment="Right" Foreground="Black" Margin="0,2,0,0" />
              </StackPanel>
            </Border>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- COMPACT SCROLLABLE DISCOVERY STRIP -->
    <Border Grid.Row="2" Background="{StaticResource AppSurface}" BorderThickness="0,1,0,1" BorderBrush="{StaticResource AppBorder}" Padding="15,10">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*, Auto">
           <TextBlock Text="NEARBY DEVICES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AppTextSecondary}" />
           <StackPanel Grid.Column="1" Orientation="Horizontal" IsVisible="{Binding IsHosting}">
              <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,0,5,0" />
              <TextBlock Text="VISIBLE" Foreground="#4CAF50" FontSize="10" FontWeight="Bold" />
           </StackPanel>
        </Grid>

        <!-- Discovery List -->
        <Border Height="100" Background="White" CornerRadius="4" BorderThickness="1" BorderBrush="#DDDDDD">
           <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding DiscoveredDevices}">
                 <ItemsControl.ItemTemplate>
                   <DataTemplate x:DataType="m:BluetoothDeviceModel">
                      <Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).ConnectCommand}" 
                              CommandParameter="{Binding}" HorizontalAlignment="Stretch" Margin="5,1" Background="#F8F8F8" Padding="12,8" CornerRadius="4">
                         <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                               <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="Black" />
                               <TextBlock Text="{Binding Id}" FontSize="9" Foreground="#666666" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#1976D2" CornerRadius="4" Padding="10,5">
                               <TextBlock Text="CONNECT" Foreground="White" FontWeight="Black" FontSize="11" />
                            </Border>
                         </Grid>
                      </Button>
                   </DataTemplate>
                 </ItemsControl.ItemTemplate>
              </ItemsControl>
           </ScrollViewer>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="10">
           <Button Content="MAKE DISCOVERABLE" Command="{Binding DiscoverableCommand}" FontSize="11" Padding="10,5" />
           <TextBlock Text="Allows peer to find this device" VerticalAlignment="Center" FontSize="10" Opacity="0.5" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Modern Input Bar -->
    <Border Grid.Row="3" Background="{StaticResource AppBackground}" Padding="15">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Content="+" Command="{Binding PickFileCommand}" Background="Transparent" Foreground="{StaticResource AppPrimary}" FontSize="24" BorderThickness="0" Padding="10,0" VerticalAlignment="Center" />
        <TextBox Grid.Column="1" Text="{Binding MessageText, Mode=TwoWay}" Watermark="Type message..." 
                 BorderThickness="1" CornerRadius="20" Background="{StaticResource AppSurface}" Foreground="Black" Padding="15,7" VerticalAlignment="Center" />
        <Button Grid.Column="2" Content="➤" Command="{Binding SendCommand}" 
                Background="{StaticResource AppPrimary}" Foreground="White" CornerRadius="20" Width="40" Height="40" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="10,0,0,0" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Status Bar -->
    <Border Grid.Row="3" VerticalAlignment="Bottom" Background="#333333" Padding="10,2" IsVisible="{Binding Status, Converter={StaticResource NotNullToVis}}">
       <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" HorizontalAlignment="Center" />
    </Border>

  </Grid>
</UserControl>
