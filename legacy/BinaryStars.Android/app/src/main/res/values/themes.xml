<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BinaryStars" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- System bars -->
        <item name="android:statusBarColor">@color/carbon_bg_panel</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/carbon_bg_panel</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Background -->
        <item name="android:windowBackground">@color/bg_light</item>
    </style>
</resources>