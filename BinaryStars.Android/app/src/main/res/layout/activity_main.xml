<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/carbon_bg_app"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/status_bar_spacer"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:background="@color/carbon_bg_panel"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/status_bar_spacer"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="@dimen/nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/carbon_bg_panel"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/nav_devices"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_devices"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Devices"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_computer"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Devices" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_files"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_files"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Files"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_folder"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Files" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_notes"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_notes"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notes"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_note"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Notes" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_messaging"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_messaging"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Messaging"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_message"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Messaging" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_map"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_map"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Map"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_map"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Map" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_actions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_actions"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Actions"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Actions" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_notifications"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_notifications"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notifications"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <!-- We reuse an icon -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_note"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Notifications" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:tag="nav_settings"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textSize="16sp"
                android:textColor="@color/carbon_text_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/carbon_text_muted"
                android:contentDescription="Settings" />

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>