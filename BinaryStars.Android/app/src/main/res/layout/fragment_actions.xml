<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/carbon_bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/carbon_bg_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Menu"
            android:src="@drawable/ic_menu" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actions"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/carbon_text_main" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/viewActionsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvActionsSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Linux devices"
            android:textAllCaps="true"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/carbon_text_muted"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvActionLinuxDevices"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/viewActionDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp">

        <Button
            android:id="@+id/btnBackToActionsList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back" />

        <TextView
            android:id="@+id/tvActionDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Device"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/carbon_text_main" />

        <TextView
            android:id="@+id/tvActionDetailMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="meta"
            android:textColor="@color/carbon_text_muted" />

        <Button
            android:id="@+id/btnBlockScreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Block Screen" />

        <Button
            android:id="@+id/btnShutdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Shut Down" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Reset" />

        <Button
            android:id="@+id/btnOpenApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Open Apps" />

        <Button
            android:id="@+id/btnCloseApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Close Apps" />

        <LinearLayout
            android:id="@+id/viewPendingActionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/pbActionPending"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/tvPendingActionStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textColor="@color/carbon_text_muted"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPendingActionTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/carbon_text_main"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/viewOpenApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Launchable Apps"
                android:textStyle="bold"
                android:textColor="@color/carbon_text_main" />

            <EditText
                android:id="@+id/etOpenAppsSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Search launchable apps"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:textColor="@color/carbon_text_main"
                android:textColorHint="@color/carbon_text_muted"
                android:background="@color/carbon_bg_app"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/listOpenApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/viewCloseApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Running Apps"
                android:textStyle="bold"
                android:textColor="@color/carbon_text_main" />

            <EditText
                android:id="@+id/etCloseAppsSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Search running apps"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:textColor="@color/carbon_text_main"
                android:textColorHint="@color/carbon_text_muted"
                android:background="@color/carbon_bg_app"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/listCloseApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvActionSupportInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/carbon_text_muted"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
